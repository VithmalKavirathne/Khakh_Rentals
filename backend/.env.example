# --- Hostinger + Supabase (production) ---
# Set these in Hostinger hPanel → Environment Variables (backend website)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
FRONTEND_URL=https://yourdomain.com
PORT=5000

# --- Authentication (required for login) ---
# Generate hash: node scripts/hash-admin-password.js "YourSecureAdminPassword"
ADMIN_USERNAME=admin@khakhrentals.com
ADMIN_PASSWORD_HASH=
JWT_SECRET=
# Optional token lifetime (default 24h)
# JWT_EXPIRES_IN=24h

# --- Local development (used when DATABASE_URL is not set) ---
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=khakh_rentals
# DB_PASSWORD=password
# DB_PORT=5432
