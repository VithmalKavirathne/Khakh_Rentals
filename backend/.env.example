# --- Production (Render) ---
# Full Postgres connection string from Render's managed database (Internal or External URL).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of allowed frontend origins (no trailing slash).
# Example for Vercel:
FRONTEND_URL=https://your-frontend.vercel.app

# Render sets PORT automatically; you usually do NOT need to set this.
# PORT=5000

# --- Local development (used only when DATABASE_URL is not set) ---
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=khakh_rentals
# DB_PASSWORD=password
# DB_PORT=5432
